# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zakevents

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Chargily Pay
CHARGILY_API_KEY=your-chargily-api-key
CHARGILY_WEBHOOK_SECRET=your-webhook-secret

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars

# Brevo (Email)
BREVO_API_KEY=your-brevo-key

# Sentry (optional)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# App
FRONTEND_URL=https://zakevents.dz
VITE_API_URL=https://your-render-app.onrender.com
NODE_ENV=production
LOG_LEVEL=info

# Feature Flags
ENABLE_AI_FEATURES=false
FF_EMAIL_REMINDERS=true
FF_ESCROW_RELEASE=true
FF_PROMETHEUS=true
AI_BUDGET_OPTIMIZER_ENABLED=false
